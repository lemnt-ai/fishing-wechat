{
  "compilerOptions": {
    "target": "ES2015",
    "module": "commonjs",
    "lib": ["ES2015", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "outDir": "./temp/declarations",
    "rootDir": "./assets",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmit": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "typeRoots": [
      "./temp/declarations",
      "./extensions"
    ],
    "types": []
  },
  "include": [
    "assets/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "library",
    "temp"
  ]
}
